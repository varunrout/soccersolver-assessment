# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# OpenAI API key — required for the NLU layer (POST /chat)
OPENAI_API_KEY=your_openai_api_key_here

# Path to the player statistics CSV, relative to backend/
# Default works for both local dev and Docker.
CSV_PATH=data/players.csv

# Port the uvicorn server listens on (used by Docker)
PORT=8000
