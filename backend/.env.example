# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# OpenAI API key — enables the LLM NLU path (POST /chat).
# When not set, parse_query() uses the deterministic rule-based fallback.
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model name (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional player portrait provider. Use PLAYER_IMAGE_PROVIDER=sportmonks for
# the documented concrete adapter, or http for a custom internal adapter.
# Credentials remain on the backend; leave blank for deterministic initials.
PLAYER_IMAGE_PROVIDER=
PLAYER_IMAGE_API_KEY=
# Only used by the generic http adapter.
PLAYER_IMAGE_API_BASE_URL=

# Path to the player statistics CSV, relative to backend/
# Default works for both local dev and Docker.
CSV_PATH=data/players.csv

# Port the uvicorn server listens on (used by Docker)
PORT=8000
