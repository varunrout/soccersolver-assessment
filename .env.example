# Root environment variables for local development and Docker Compose.
# Copy to .env before running.

# Optional: enables OpenAI-assisted intent parsing in the backend.
# If unset, the deterministic rule-based parser is used.
OPENAI_API_KEY=

# Optional: OpenAI model override used by backend nlu/parser.py.
OPENAI_MODEL=gpt-4o-mini

# Optional: backend-only player portrait provider. Set to sportmonks for the
# documented concrete adapter, or http for a custom internal adapter.
PLAYER_IMAGE_PROVIDER=
PLAYER_IMAGE_API_KEY=
# Only used by the generic http adapter.
PLAYER_IMAGE_API_BASE_URL=

# Frontend API base URL (used by Vite at build/dev time).
VITE_API_BASE_URL=http://localhost:8000
