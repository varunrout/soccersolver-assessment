# SoccerSolver — root environment variables for Docker Compose
#
# Copy to .env and fill in values before running:
#   cp .env.example .env
#   docker-compose up --build

# OpenAI key — required for the /chat endpoint (Issue #11)
OPENAI_API_KEY=sk-...

# Backend URL as seen from the user's *browser* (not from inside Docker).
# Default works for local Docker Compose where backend is on the host at :8000.
VITE_API_BASE_URL=http://localhost:8000
